                      </div>
                      <h3 className="text-base sm:text-lg font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors">
                        {t('resources.materials.downloadable.guide2.title')}
                      </h3>
                      <p className="text-gray-600 text-xs sm:text-sm mb-4 leading-relaxed">
                        {t('resources.materials.downloadable.guide2.description')}
                      </p>
                      <div className="flex items-center justify-between text-xs sm:text-sm text-gray-500 mb-4">
                        <span>{t('resources.materials.downloadable.guide2.source')}</span>
                        <span>{t('resources.materials.downloadable.guide2.size')}</span>
                      </div>
                      <Button variant="secondary" disabled className="w-full justify-center">
                        {t('resources.materials.downloadable.guide2.cta')}
                      </Button>
                    </div>
                  </CardContent>
                </Card>

                <Card className="group hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 border-2 hover:border-green-300">
                  <CardContent className="relative overflow-hidden">
                    {/* Shine Effect */}
                    <div className="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700">
                      <div className="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
                    </div>
                    
                    <div className="relative z-10">
                      <div className="flex items-center mb-4">
                        <div className="w-12 h-12 sm:w-14 sm:h-14 bg-gradient-to-br from-green-100 to-green-200 rounded-xl flex items-center justify-center mr-3 shadow-md">
                          <svg className="w-6 h-6 sm:w-7 sm:h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                          </svg>
                        </div>
                        <Badge variant="success" className="shadow-sm">
                          PDF Report
