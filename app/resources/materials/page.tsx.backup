                      >
                        <Button variant="primary" icon={ExternalLink} className="w-full justify-center group-hover:scale-105 transition-transform duration-300">
                          {t('resources.materials.downloadable.report.cta')}
                        </Button>
                      </a>
                    </div>
                  </CardContent>
                </Card>
              </div>
            </div>
