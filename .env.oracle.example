# Oracle Autonomous JSON Database Configuration
# Copy this to your .env.local file and update with your actual Oracle connection details

# Your existing MongoDB connection (keep as backup)
MONGDB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# Oracle Autonomous JSON Database connection string
# Format: mongodb://username:password@hostname:port/database
# Replace with your actual Oracle Autonomous JSON Database connection details
ORACLE_MONGODB_URI=mongodb://username:password@your-oracle-host:27017/your-database

# Example Oracle connection string format:
# ORACLE_MONGODB_URI=mongodb://ADMIN:YourPassword@your-autonomous-db-host.oraclecloud.com:27017/your_database_name

# Notes:
# 1. Get your connection details from Oracle Cloud Console
# 2. Navigate to your Autonomous JSON Database instance
# 3. Click on "Database Connection" 
# 4. Copy the MongoDB API connection string
# 5. Replace username and password with your database credentials
# 6. The mongoose.ts file will automatically use Oracle if ORACLE_MONGODB_URI is set

# Other environment variables (keep your existing ones)
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret