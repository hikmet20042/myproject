  "about": {
    "ourMission": "Gəncləri və İcmaları Gücləndir",
    "missionSubtitle": "Azərbaycanda gəncləri fürsətlərlə, təşkilatlarla və bir-biri ilə əlaqələndirərək gənc insanları və icma təşəbbüslərini gücləndirmək.",
    "dataChallenge": "Gənclərin Qarşılaşdığı Çətinliklər",
    "dataChallengeSubtitle": "Azərbaycanda bir çox gənc fürsətlər, təlimlər və ya könüllülük proqramları haqqında etibarlı məlumata çıxış əldə etməkdə çətinlik çəkir.",
    "whyUnreliable": "Əsas Çətinliklər",
    "culturalStigma": "Dağınıq Məlumat",
    "culturalStigmaText": "Fürsətlər haqqında məlumat parçalanmış və struktursuz olub, gənclərin müvafiq proqramları kəşf etməsini çətinləşdirir.",
    "institutionalGaps": "Zəif Əlaqələr",
    "institutionalGapsText": "QHT-lər və gənclər arasında məhdud qarşılıqlı əlaqə sosial təşəbbüslərdə iştirak üçün maneələr yaradır.",
    "limitedTransparency": "Məhdud Platformalar",
    "limitedTransparencyText": "Təcrübələri və uğur hekayələrini paylaşmaq üçün xüsusi məkanların olmaması həmyaşıdlardan öyrənməni və ruhlandırmanı məhdudlaşdırır.",
    "resourceConstraints": "Resurslara Çıxış",
    "resourceConstraintsText": "Şəxsi və peşəkar inkişaf resurslarına kifayət qədər çıxışın olmaması gənclərin potensialını məhdudlaşdırır.",
    "theImpact": "Bizim Həllimiz",
    "impactIntro": "icma360 gənclərin və təşkilatların görüşdüyü, öyrəndiyi və birlikdə böyüdüyü rəqəmsal ekosistemdir:",
    "developStrategies": "Kateqoriya əsaslı filtrləmə ilə fürsətləri daha sürətli tapın",
    "allocateResources": "QHT-lər və icma təşəbbüsləri ilə birbaşa əlaqə qurun",
    "measureProgress": "Təcrübələri paylaşın və həmyaşıdlardan öyrənin",
    "advocatePolicy": "Pulsuz öyrənmə və inkişaf resurslarına çıxış",
    "technologyApproach": "Platformanın Xüsusiyyətləri",
    "technologySubtitle": "Gəncləri fürsətlər, icma və təhsil resursları ilə əlaqələndirən mərkəzləşdirilmiş mərkəz.",
    "newsScraping": "Fürsətlər Mərkəzi",
    "newsScrapingText": "Azərbaycan üzrə QHT-lər və icma təşəbbüslərindən gənclər proqramlarını, təcrübələri və könüllülük fürsətlərini tapın.",
    "multipleSourcesDaily": "Mövzu, tarix və yerə görə kateqoriya əsaslı filtrasiya",
