  "home": {
    "heroTitle": "Azərbaycanda Gənclərin və İcmaların İnkişafına Dəstək",
    "heroSubtitle": "Gəncləri, QHT-ləri və sosial təşəbbüsləri bir araya gətirərək öyrənmə, əməkdaşlıq və inkişaf fürsətləri yaradan ictimai platforma.",
    "discoverOpportunities": "Fürsətləri Kəşf Et",
    "communityStories": "İcma Bloqları",
    "shareExperience": "Təcrübəni Paylaş",
    "ourMission": "Missiyamız",
    "missionText1": "Bugün bir çox gənc və sosial təşəbbüs inkişaf, əlaqə və görünürlük baxımından çətinliklərlə üzləşir. Bizim missiyamız — gənclərin və təşkilatların bir-biri ilə əlaqə qura, öyrənə və yeni fürsətlərə çıxış əldə edə bildiyi inklüziv rəqəmsal məkan yaratmaqdır.",
    "missionText2": "Biz inanırıq ki, əlaqə, əməkdaşlıq və təhsil davamlı inkişafın təməlidir.",
    "transparentInfo": "Şəffaf Məlumat və Fürsətlər",
    "transparentInfoText": "Yerli və beynəlxalq təşkilatların təsdiqlənmiş və mütəmadi yenilənən fürsətləri, könüllülük proqramları və təcrübə elanları.",
    "learningDevelopment": "Öyrənmə və İnkişaf",
    "learningDevelopmentText": "Gənclərin şəxsi, sosial və karyera bacarıqlarını inkişaf etdirməsi üçün pulsuz tədris materialları, resurslar və təlimlər.",
    "communitySharing": "İcma və Təcrübə Paylaşımı",
    "communitySharingText": "Gənclərin təcrübələrini, uğur hekayələrini və ideyalarını bloq və həmyaşıd müzakirələri vasitəsilə paylaşdığı açıq icma məkanı.",
    "joinMakeDifference": "Qoşul və Fərq Yarat",
    "joinText1": "Gənclərin bir-biri ilə əlaqə qurduğu və birgə inkişaf etdiyi icmanın bir hissəsi ol.",
    "joinText2": "Fürsət tapmaq, təcrübəni bölüşmək və təşkilatlarla əlaqə qurmaq istəyirsənsə — icma360 sənə inkişaf və töhfə vermək üçün bütün imkanları təqdim edir.",
    "disclaimer": "Bu platforma əlaqə və məlumat paylaşımını asanlaşdırır. Fürsətləri həmişə müstəqil şəkildə yoxlayın və şəxsi məlumat paylaşarkən ehtiyatlı olun."
  },
