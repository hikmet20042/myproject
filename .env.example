# ===========================================# Database

# ENVIRONMENT CONFIGURATION TEMPLATEMONGODB_URI=your_mongodb_connection_string

# ===========================================

# Copy this file to .env and fill in your actual values# NextAuth

NEXTAUTH_URL=http://localhost:3000

# -----------------NEXTAUTH_SECRET=your_nextauth_secret

# Application URLs

# -----------------# Cron Job Secret (for event deadline notifications)

NEXTAUTH_URL=http://localhost:3000CRON_SECRET=your_secure_random_string_here

NEXT_PUBLIC_APP_URL=http://localhost:3000

SITE_URL=https://yourdomain.com# Email (if using email notifications)

EMAIL_SERVER=smtp://username:password@smtp.example.com:587

# -----------------EMAIL_FROM=noreply@yourdomain.com

# NextAuth Secret

# -----------------# Cloudinary (for image uploads)

# Generate a new secret: openssl rand -base64 32NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

NEXTAUTH_SECRET=your_nextauth_secret_hereCLOUDINARY_API_KEY=your_api_key

CLOUDINARY_API_SECRET=your_api_secret

# -----------------

# Environment Mode# Google OAuth (if using)

# -----------------GOOGLE_CLIENT_ID=your_google_client_id

NODE_ENV=developmentGOOGLE_CLIENT_SECRET=your_google_client_secret



# -----------------# Socket.IO (when implemented)

# Database ConnectionsNEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# -----------------
# Primary MongoDB Connection
MONGODB_URI=your_mongodb_connection_string

# Oracle Autonomous JSON Database MongoDB API (Optional - Alternative/Backup)
# ORACLE_MONGODB_URI=mongodb://username:password@hostname:27017/database

# -----------------
# Email Configuration (Brevo SMTP)
# -----------------
EMAIL_SERVER_HOST=smtp-relay.brevo.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your_brevo_smtp_user
EMAIL_SERVER_PASSWORD=your_brevo_smtp_password
EMAIL_FROM=your_email@example.com

# -----------------
# OAuth Configuration
# -----------------
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# -----------------
# Cloudinary Configuration
# -----------------
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# -----------------
# AI Provider API Keys (Optional)
# -----------------
OPENROUTER_API_KEY=your_openrouter_api_key
GEMINI_API_KEY=your_gemini_api_key
MISTRAL_API_KEY=your_mistral_api_key

# -----------------
# Socket.IO Configuration
# -----------------
# Set to false when deploying to Vercel or other serverless platforms
NEXT_PUBLIC_ENABLE_SOCKET=true

# -----------------
# Admin/Test User Credentials (for initialization scripts)
# -----------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure_admin_password
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=secure_test_password

# -----------------
# Cron Job Security
# -----------------
# Generate a secure random string for cron job authentication
CRON_SECRET=your_secure_random_string_here
