# Application URLs
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=https://icma360.az

# SEO & Analytics
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_verification_code_here
NEXT_PUBLIC_YANDEX_VERIFICATION=your_yandex_verification_code_here
NEXT_PUBLIC_BING_VERIFICATION=your_bing_verification_code_here
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Secrets
NEXTAUTH_SECRET=your_nextauth_secret_here
CRON_SECRET=your_secure_random_string_here

# Environment
NODE_ENV=development

# Database
MONGODB_URI=your_mongodb_connection_string
# ORACLE_MONGODB_URI=mongodb://username:password@hostname:27017/database

# Email (Brevo)
EMAIL_SERVER_HOST=smtp-relay.brevo.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your_brevo_smtp_user
EMAIL_SERVER_PASSWORD=your_brevo_smtp_password
EMAIL_FROM=your_email@example.com

# OAuth (Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Providers
OPENROUTER_API_KEY=your_openrouter_api_key
GEMINI_API_KEY=your_gemini_api_key
MISTRAL_API_KEY=your_mistral_api_key

# Socket.IO
NEXT_PUBLIC_ENABLE_SOCKET=true

# Admin/Test Users
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure_admin_password
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=secure_test_password
