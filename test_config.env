# Test Configuration File
# Copy this to .env.test and fill in your actual credentials

# Server Configuration
TEST_BASE_URL=http://localhost:3000

# Admin Credentials (required for admin tests)
# Use your actual admin email and password
ADMIN_EMAIL=hikmat.mammadlii@gmail.com
ADMIN_PASSWORD=your_admin_password_here

# Optional: Pre-existing test accounts (if you want to skip registration)
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=TestPassword123!

TEST_NGO_EMAIL=testngo@example.com
TEST_NGO_PASSWORD=TestPassword123!

# Test Configuration
# Set to 'true' to cleanup test data after tests complete
CLEANUP_TEST_DATA=false

# Set to 'true' to run destructive tests (delete operations)
RUN_DESTRUCTIVE_TESTS=false
